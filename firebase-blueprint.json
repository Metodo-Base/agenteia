{
  "entities": {
    "lead": {
      "title": "Lead",
      "description": "A potential customer who submitted the contact form.",
      "type": "object",
      "properties": {
        "nome": {
          "type": "string",
          "description": "Full name of the lead."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the lead."
        },
        "whatsapp": {
          "type": "string",
          "description": "WhatsApp number of the lead."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the lead was created."
        }
      },
      "required": ["nome", "email", "whatsapp", "createdAt"]
    },
    "nicho": {
      "title": "Nicho",
      "description": "A business niche for AI agents.",
      "type": "object",
      "properties": {
        "nome_nicho": {
          "type": "string",
          "description": "Name of the niche."
        },
        "prompt_inicial": {
          "type": "string",
          "description": "Initial prompt for the AI agent in this niche."
        },
        "slug": {
          "type": "string",
          "description": "Unique URL-friendly identifier for the niche."
        }
      },
      "required": ["nome_nicho", "prompt_inicial", "slug"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "lead",
      "description": "Collection of leads from the landing page."
    },
    "nichos/{nichoId}": {
      "schema": "nicho",
      "description": "Collection of business niches."
    }
  }
}
